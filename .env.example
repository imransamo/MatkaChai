NEXT_PUBLIC_SITE_URL=https://matkachai.pk
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLIC_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SECRET_SERVICE_ROLE_KEY
NEXT_PUBLIC_GOOGLE_MAPS_URL=https://maps.google.com/?q=Creek+Walk+DHA+Phase+8+Karachi
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# Full conversational ordering assistant. The site has a limited fallback without these.
OPENAI_API_KEY=YOUR_SECRET_OPENAI_API_KEY
OPENAI_CHAT_MODEL=gpt-5.4-mini

# Manager notification by email. The order remains in Supabase if delivery fails.
MANAGER_NOTIFICATION_EMAIL=manager@example.com
MANAGER_WHATSAPP_NUMBER=923337571119
RESEND_API_KEY=YOUR_SECRET_RESEND_KEY
ORDER_NOTIFICATION_FROM=Matka Chai Orders <orders@matkachai.pk>

# WhatsApp Business Cloud API credentials for automatic order and hot-lead alerts.
WHATSAPP_ACCESS_TOKEN=YOUR_META_WHATSAPP_ACCESS_TOKEN
WHATSAPP_PHONE_NUMBER_ID=YOUR_META_PHONE_NUMBER_ID
WHATSAPP_GRAPH_VERSION=v23.0

# Optional additional or alternative alert destination (Make, Zapier, or an internal system).
ORDER_NOTIFICATION_WEBHOOK_URL=
